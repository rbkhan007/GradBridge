# Database — PostgreSQL + pgvector for production (Vercel + Neon/Supabase)
#
# RULE: Always use PostgreSQL in production. pgvector requires PostgreSQL.
# RULE: Run `npx prisma db push --schema=prisma/schema.prisma` after switching.
# RULE: Enable the vector extension: CREATE EXTENSION IF NOT EXISTS vector;
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gradbridge?schema=public"

# For local SQLite dev (uncomment below, comment out the PostgreSQL line above):
# DATABASE_URL="file:./db/custom.db"
# IMPORTANT: Also change provider = "sqlite" in prisma/schema.prisma
# and change VectorEmbedding.embedding from Unsupported("vector(1536)")? to String?

# LLM Providers (optional — falls back to local responder if unavailable)
# ZAI_API_KEY="your-api-key"

# OpenRouter — provides free tier + user API keys
# OPENROUTER_API_KEY="sk-or-v1-..."
# OPENROUTER_MODEL="deepseek/deepseek-coder"
# OPENROUTER_FALLBACK_KEY="sk-or-v1-..."  # shared free tier key (5 msg/day)

# Groq (optional — fast inference)
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"

# Ollama (optional — local models)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="qwen2.5-coder:7b"

# Session secret (auto-generated per instance if not set)
# In production, set this for persistent sessions across restarts
# GRADBRIDGE_SECRET="your-secret-key"
