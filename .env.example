# =============================================================================
# GradBridge — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values.
# Docker Compose reads .env automatically.
# =============================================================================

# ─── Database (PostgreSQL + pgvector via Docker) ──────────────────────────────
# Default matches docker-compose.yml postgres service
DATABASE_URL="postgresql://gradbridge:gradbridge@postgres:5432/gradbridge?schema=public"

# ─── Session Security ─────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GRADBRIDGE_SECRET=""

# ─── LLM Providers ────────────────────────────────────────────────────────────
# All optional — falls back to local responder if no provider configured.

# Zai SDK (primary)
ZAI_API_KEY=""

# OpenRouter (free tier + user API keys)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-coder"
# Shared fallback key: 5 free messages/day per user when they have no custom key
OPENROUTER_FALLBACK_KEY=""

# Groq (fast inference, free tier)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Ollama (local models — optional)
OLLAMA_BASE_URL=""
OLLAMA_MODEL=""

# ─── Docker Compose (override defaults) ──────────────────────────────────────
POSTGRES_USER=gradbridge
POSTGRES_PASSWORD=gradbridge
POSTGRES_DB=gradbridge
PGADMIN_EMAIL=admin@gradbridge.com
PGADMIN_PASSWORD=admin
